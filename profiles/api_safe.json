{
  "_description": "API-safe profile. Designed for programmatic access (n8n, webhooks, automation). Strict safety, raw prompt mode, structured outputs.",
  "prompt_filter": {
    "ml_threshold": 0.70,
    "risk_threshold": 4,
    "ml_enabled": true
  },
  "image_filter": {
    "nsfw_block_threshold": 0.50,
    "nsfw_warn_threshold": 0.25,
    "age_check_enabled": true
  },
  "prompt_engine": {
    "default_mode": "balanced"
  },
  "generation": {
    "max_concurrent": 1,
    "queue_timeout_seconds": 600
  },
  "n8n": {
    "enabled": true,
    "token": "REPLACE_WITH_YOUR_SECRET_TOKEN",
    "callback_url": "https://your-n8n-cloud.app.n8n.cloud/webhook/cookiefooocus"
  },
  "rate_limit": {
    "max_requests_per_window": 20,
    "window_seconds": 60
  }
}
